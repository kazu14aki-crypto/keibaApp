# --- このファイルを .env にコピーして値を埋めてください ---
# ローカル開発用。Render.com本番環境では、Renderの管理画面の
# Environment タブで同じキーを設定してください（.envファイルは使われません）。

# あなた専用のログインパスワード（自由に決めてください。16文字以上推奨）
APP_PASSWORD=change-me-to-a-strong-password

# JWTトークンの署名用シークレット（ランダムな長い文字列。下記コマンドで生成できます）
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ログインセッションの有効期限（時間）。既定は168時間＝7日間。
JWT_EXPIRE_HOURS=168

# Neonダッシュボード → Connection string からコピー
# 例: postgresql://user:password@ep-xxxx.ap-northeast-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# フロントエンドのURL（カンマ区切りで複数可）。
# デプロイ後、実際のVercel/Netlify/RenderのURLに置き換えてください。
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
